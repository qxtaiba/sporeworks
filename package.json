{
  "name": "sporeworks",
  "version": "0.1.0",
  "description": "a seeded sdf organism engine — halftone-screened creatures grown in a shader, rendered off-thread",
  "license": "MIT",
  "author": "Qutaiba Al-Nuaimy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qxtaiba/sporeworks.git"
  },
  "homepage": "https://github.com/qxtaiba/sporeworks#readme",
  "bugs": {
    "url": "https://github.com/qxtaiba/sporeworks/issues"
  },
  "keywords": [
    "webgl",
    "sdf",
    "raymarching",
    "generative",
    "halftone",
    "custom-element",
    "offscreencanvas",
    "web-worker"
  ],
  "type": "module",
  "main": "./dist/grappleberry.js",
  "module": "./dist/grappleberry.js",
  "exports": {
    ".": "./dist/grappleberry.js",
    "./grappleberry.js": "./dist/grappleberry.js"
  },
  "sideEffects": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0",
    "build": "tsc --noEmit && node scripts/build-engine.mjs",
    "build:app": "tsc --noEmit && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:worker": "vite build --config vite.worker.config.ts",
    "test": "vitest run",
    "test:render": "npm run build:app && npm run build && node scripts/test.mjs",
    "render": "node scripts/render.mjs",
    "gif": "node scripts/render-gif.mjs",
    "contact-sheet": "node scripts/contact-sheet.mjs",
    "seed-sheet": "node scripts/seed-sheet.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run build"
  },
  "devDependencies": {
    "puppeteer-core": "^24.10.2",
    "sharp": "^0.35.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
